---
import Layout from '../layouts/Layout.astro';
import PricingTiers from '../components/PricingTiers.astro';
import { getTattoosPricing } from '../lib/pricing';
import { getSiteConfig } from '../lib/gallery';

const site = getSiteConfig();
const pricing = getTattoosPricing();
---

<Layout title={`Tattoos — ${site.artistName}`} description="Tattoo design tiers and pricing by Kirsty" wide>
  <section class="page-header">
    <h1>Tattoos</h1>
    <p>Compare tiers side by side</p>
  </section>

  <PricingTiers data={pricing} />
</Layout>
