---
import { getSiteConfig } from '../lib/gallery';

const site = getSiteConfig();
const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <a href="/" class="brand">
    <span class="brand-name">{site.artistName}</span>
  </a>
  <nav aria-label="Main">
    <a href="/" class:list={['nav-link', { active: currentPath === '/' }]}>Home</a>
    <a href="/tattoos" class:list={['nav-link', { active: currentPath === '/tattoos' }]}>Tattoos</a>
    <a href="/commissions" class:list={['nav-link', { active: currentPath === '/commissions' }]}>Commissions</a>
    <a href="/about" class:list={['nav-link', { active: currentPath === '/about' }]}>About</a>
  </nav>
</header>
